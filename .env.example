# Korea Investment & Securities Open API credentials
KIS_ID=YOUR_HTS_ID
KIS_ACCOUNT=00000000-01
KIS_APPKEY=YOUR_36_CHARACTER_APP_KEY
KIS_SECRETKEY=YOUR_180_CHARACTER_APP_SECRET

# Optional virtual-investment credentials
KIS_VIRTUAL_ID=YOUR_VIRTUAL_HTS_ID
KIS_VIRTUAL_ACCOUNT=00000000-01
KIS_VIRTUAL_APPKEY=YOUR_36_CHARACTER_VIRTUAL_APP_KEY
KIS_VIRTUAL_SECRETKEY=YOUR_180_CHARACTER_VIRTUAL_APP_SECRET

# Optional local token cache directory
KIS_KEEP_TOKEN_DIR=.kis

# Optional official-sample compatible request settings
KIS_CUSTTYPE=P
KIS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/114.0.0.0 Safari/537.36
KIS_REAL_DOMAIN=https://openapi.koreainvestment.com:9443
KIS_VIRTUAL_DOMAIN=https://openapivts.koreainvestment.com:29443
KIS_WEBSOCKET_REAL_DOMAIN=ws://ops.koreainvestment.com:21000
KIS_WEBSOCKET_VIRTUAL_DOMAIN=ws://ops.koreainvestment.com:31000

# Official kis_devlp.yaml equivalents:
# my_app=KIS_APPKEY, my_sec=KIS_SECRETKEY, my_htsid=KIS_ID
# my_acct_stock + my_prod=KIS_ACCOUNT
# paper_app=KIS_VIRTUAL_APPKEY, paper_sec=KIS_VIRTUAL_SECRETKEY
# my_paper_stock + my_prod=KIS_VIRTUAL_ACCOUNT
# prod/vps/ops/vops map to the domain variables above.

# Set to 1 only when running live integration tests against KIS.
RUN_KIS_INTEGRATION=0
